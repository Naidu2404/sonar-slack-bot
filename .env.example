# Copy this to .env and fill in the values (never commit .env to git)

# Slack Bot Token (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# Slack App Token for Socket Mode (starts with xapp-)
SLACK_APP_TOKEN=xapp-your-app-token

# Default SonarCloud token — used for all repos unless a repo has its own token
SONAR_TOKEN=your-sonarcloud-token

# Optional: path for the SQLite database file
# DB_PATH=sonar_bot.db
